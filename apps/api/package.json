{
  "name": "@effect-starter/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsup src/main.ts --format esm --target node24 --out-dir dist --clean",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@effect-starter/contracts": "workspace:*",
    "@effect/cluster": "^0.58.2",
    "@effect/experimental": "^0.60.0",
    "@effect/platform": "^0.96.1",
    "@effect/platform-node": "^0.106.0",
    "@effect/rpc": "^0.75.1",
    "@effect/sql": "^0.51.1",
    "@effect/workflow": "^0.18.1",
    "drizzle-orm": "^0.44.0",
    "effect": "^3.21.2",
    "postgres": "^3.4.7"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "drizzle-kit": "^0.31.0",
    "tsup": "^8.5.0",
    "tsx": "^4.20.0",
    "vitest": "^4.0.0"
  }
}
